{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "ignore": ["examples/**", "tests/runtime/**", ".claude/**"],
      "ignoreDependencies": [
        "@textlint/textlint-plugin-markdown",
        "@unified-live/core",
        "@unified-live/twitcasting",
        "@unified-live/twitch",
        "@unified-live/youtube",
        "textlint-rule-preset-ja-technical-writing",
        "wrangler"
      ]
    },
    "packages/core": {
      "project": ["src/**/*.ts"],
      "ignore": ["dist/**", "node_modules/**"],
      "ignoreDependencies": ["@opentelemetry/api"]
    },
    "packages/youtube": {
      "project": ["src/**/*.ts"],
      "ignore": ["dist/**", "node_modules/**", "src/generated/**"]
    },
    "packages/twitch": {
      "project": ["src/**/*.ts"],
      "ignore": ["dist/**", "node_modules/**"]
    },
    "packages/twitcasting": {
      "project": ["src/**/*.ts"],
      "ignore": ["dist/**", "node_modules/**"]
    },
    "apps/docs": {
      "ignore": ["dist/**", "node_modules/**", ".astro/**"],
      "ignoreDependencies": ["sharp"]
    }
  }
}
