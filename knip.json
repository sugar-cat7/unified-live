{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreBinaries": ["tiup", "pkill"],
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@textlint/textlint-plugin-markdown",
        "textlint-rule-preset-ja-technical-writing"
      ]
    },
    "services/web": {
      "entry": ["app/**/{page,layout,loading,error,not-found,route,global-error}.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": [".next/**", "node_modules/**"],
      "ignoreDependencies": [
        "tailwindcss"
      ],
      "next": {
        "config": "next.config.ts"
      }
    },
    "services/api": {
      "entry": ["cmd/*.ts", "local/**/*.ts"],
      "project": ["**/*.ts"],
      "ignore": ["dist/**", "drizzle/**", "node_modules/**", "infra/http/hono/openapi.ts", "infra/repository/txManager.ts"]
    },
    "packages/errors": {
      "project": ["*.ts"],
      "ignore": ["dist/**", "node_modules/**"]
    },
    "packages/logger": {
      "project": ["*.ts"],
      "ignore": ["dist/**", "node_modules/**"]
    }
  }
}
