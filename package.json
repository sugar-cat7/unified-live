{
  "name": "my-app-template",
  "description": "Full-stack web application template with Next.js, Hono API, and essential integrations",
  "scripts": {
    "dev:next": "pnpm --filter web dev",
    "dev": "pnpm tiup:up && dotenv -e .env.local -- turbo dev",
    "build": "turbo build",
    "tiup:start": "tiup playground",
    "tiup:up": "tiup playground --host 0.0.0.0 & pnpm tiup:wait-ready && pnpm tiup:setup",
    "tiup:up:ci": "tiup playground --db 1 --pd 1 --kv 1 --tiflash 0 --without-monitor & pnpm tiup:wait-ready && pnpm tiup:setup:ci",
    "tiup:wait-ready": "until nc -z 127.0.0.1 4000 2>/dev/null; do sleep 1; done",
    "tiup:setup": "pnpm --filter api db:migrate",
    "tiup:setup:ci": "pnpm --filter api db:push",
    "clean:server": "docker compose down && pkill tiup && pkill drizzle-kit",
    "db:studio": "pnpm --filter api db:studio &",
    "db:generate": "pnpm --filter api db:generate",
    "type-check": "turbo type-check",
    "biome": "turbo biome",
    "textlint": "textlint \"{README.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "docker compose -f compose.test.yaml run --rm --build test-all",
    "test:unit": "docker compose -f compose.test.yaml run --rm --build test-unit",
    "test:integration": "docker compose -f compose.test.yaml run --rm --build test-integration",
    "test:coverage": "docker compose -f compose.test.yaml run --rm --build test-coverage",
    "test:clean": "docker compose -f compose.test.yaml down --rmi local --remove-orphans",
    "storybook": "pnpm --filter web storybook",
    "security-scan": "./scripts/security-scan.sh",
    "security-scan:docker": "./scripts/security-scan.sh --docker"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "@types/node": "catalog:",
    "dotenv-cli": "^11.0.0",
    "knip": "^5.82.1",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "turbo": "2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.24.0"
}
