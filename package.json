{
  "name": "unified-live",
  "private": true,
  "description": "A TypeScript SDK providing a unified interface for live streaming platform APIs",
  "scripts": {
    "build": "turbo build",
    "type-check": "turbo type-check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "textlint": "textlint \"{README.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "turbo test:run",
    "test:run": "turbo test:run",
    "test:coverage": "turbo test:coverage",
    "security-scan": "./scripts/security-scan.sh",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "@types/node": "catalog:",
    "@unified-live/core": "workspace:*",
    "@unified-live/twitcasting": "workspace:*",
    "@unified-live/twitch": "workspace:*",
    "@unified-live/youtube": "workspace:*",
    "knip": "^5.82.1",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.51.0",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "tsx": "^4.19.0",
    "turbo": "2.6.3",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.76.0"
  },
  "packageManager": "pnpm@10.24.0"
}
