{
  "name": "unified-live",
  "description": "A TypeScript SDK providing a unified interface for live streaming platform APIs",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "type-check": "turbo type-check",
    "lint": "oxlint",
    "textlint": "textlint \"{README.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "turbo test:run",
    "test:run": "turbo test:run",
    "test:coverage": "turbo test:coverage",
    "security-scan": "./scripts/security-scan.sh"
  },
  "devDependencies": {
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "@types/node": "catalog:",
    "knip": "^5.82.1",
    "oxlint": "^1.51.0",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "turbo": "2.6.3",
    "vitest": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.24.0"
}
