{
  "name": "@unified-live/twitch",
  "version": "0.1.1",
  "description": "Twitch Helix API plugin for unified-live SDK — token bucket rate limiting, OAuth2 Client Credentials",
  "keywords": [
    "live-streaming",
    "sdk",
    "twitch",
    "twitch-api",
    "typescript"
  ],
  "homepage": "https://sugar-cat7.github.io/unified-live",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugar-cat7/unified-live.git",
    "directory": "packages/twitch"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc --noEmit",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@unified-live/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
