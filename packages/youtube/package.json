{
  "name": "@unified-live/youtube",
  "version": "0.0.1",
  "description": "YouTube Data API v3 plugin for unified-live SDK — quota-based rate limiting, API key auth",
  "keywords": [
    "live-streaming",
    "sdk",
    "typescript",
    "youtube",
    "youtube-api"
  ],
  "homepage": "https://sugar-cat7.github.io/unified-live",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugar-cat7/unified-live.git",
    "directory": "packages/youtube"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "generate:types": "tsx ../../scripts/generate-youtube-types.ts",
    "build": "tsdown",
    "type-check": "tsc --noEmit",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@unified-live/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
