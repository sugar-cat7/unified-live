{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":maintainLockFilesWeekly",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "timezone": "Asia/Tokyo",
  "schedule": ["after 9am and before 5pm on weekdays"],
  "prHourlyLimit": 3,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  },
  "pnpm": {
    "supportCatalog": true
  },
  "enabledManagers": ["npm", "github-actions"],
  "packageRules": [
    {
      "description": "Shared packages branch prefix",
      "matchFileNames": ["packages/*/package.json"],
      "additionalBranchPrefix": "packages-"
    },
    {
      "description": "Automerge minor/patch for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update", "requires-review"],
      "automerge": false
    },
    {
      "description": "Core shared: Zod",
      "groupName": "shared-zod",
      "matchPackageNames": ["zod"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Monorepo tooling",
      "groupName": "shared-monorepo",
      "matchPackageNames": ["turbo", "typescript", "tsup", "knip"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Linting (oxlint)",
      "groupName": "shared-linting",
      "matchPackageNames": ["oxlint"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Testing (Vitest)",
      "groupName": "shared-testing",
      "matchPackageNames": ["vitest", "/^@vitest//"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "pnpm package manager",
      "matchPackageNames": ["pnpm"],
      "matchDepTypes": ["packageManager"],
      "labels": ["pnpm"],
      "automerge": false
    }
  ]
}
