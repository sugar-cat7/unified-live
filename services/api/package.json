{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local cmd/index.ts",
    "dev:ci": "tsx watch cmd/index.ts",
    "db:wait-ready": "tsx --env-file=../../.env.local local/db/wait-for-db.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "biome:check": "biome check ./**/** --fix --unsafe",
    "biome:format": "biome format --write ./**/**",
    "biome:lint": "biome lint ./**/**",
    "biome:unsafe-fix": "biome check --fix --unsafe",
    "db:generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env.local -- drizzle-kit push --force",
    "db:studio": "dotenv -e ../../.env.local -- drizzle-kit studio --host=0.0.0.0 --port=3005",
    "db:seed": "tsx --env-file=../../.env.local local/db/seed.ts",
    "db:seed:ci": "tsx local/db/seed.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.0",
    "@my-app/dayjs": "workspace:*",
    "@my-app/errors": "workspace:*",
    "@my-app/logger": "workspace:*",
    "@tidbcloud/serverless": "^0.2.0",
    "better-auth": "^1.4.17",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.5",
    "mysql2": "^3.16.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
