{
  "name": "web",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev:https": "next dev --turbopack --port 3001 --experimental-https --experimental-https-key ./certificates/key.pem --experimental-https-cert ./certificates/cert.pem",
    "dev": "next dev --turbopack --port 3001",
    "lint": "next lint",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "biome:check": "biome check ./**/** --fix --unsafe",
    "biome:format": "biome format --write ./**/**",
    "biome:lint": "biome lint ./**/**",
    "biome:unsafe-fix": "biome check --fix --unsafe",
    "storybook": "storybook dev -p 6006",
    "storybook:https": "storybook dev -p 6006 --https --ssl-cert ./certificates/cert.pem --ssl-key ./certificates/key.pem",
    "storybook:build": "storybook build -o storybook-static",
    "vrt": "pnpm storybook:build && docker compose -f vrt/docker-compose.yml run --rm vrt",
    "vrt:update": "pnpm storybook:build && docker compose -f vrt/docker-compose.yml run --rm vrt --update-snapshots"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "better-auth": "^1.4.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@playwright/test": "^1.58.0",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/nextjs-vite": "^10.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser-playwright": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "msw": "^2.12.7",
    "msw-storybook-addon": "^2.0.6",
    "storybook": "^10.2.0",
    "typescript": "catalog:",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
