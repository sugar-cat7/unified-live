{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "tsdown.config.ts", "package.json"],
      "outputs": ["dist/**"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "tsconfig.json", "package.json"]
    },
    "test:run": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "//#lint": {
      "cache": false
    },
    "//#knip": {
      "cache": false,
      "inputs": ["knip.json", "packages/*/src/**", "packages/*/package.json"]
    },
    "//#knip:fix": {
      "cache": false
    }
  }
}
