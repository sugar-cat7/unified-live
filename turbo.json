{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:run": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "//#lint": {
      "cache": false
    },
    "//#knip": {
      "cache": false,
      "inputs": [
        "knip.json",
        "packages/*/src/**",
        "packages/*/package.json"
      ]
    },
    "//#knip:fix": {
      "cache": false
    }
  }
}
