{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:run": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "biome:check": {
      "cache": false
    },
    "biome:format": {
      "dependsOn": ["biome:check"],
      "cache": false
    },
    "biome:unsafe-fix": {
      "dependsOn": ["biome:format"],
      "cache": false
    },
    "biome:lint": {
      "dependsOn": ["biome:unsafe-fix"],
      "cache": false
    },
    "biome": {
      "dependsOn": ["biome:lint"],
      "cache": false
    },
    "//#knip": {
      "cache": false,
      "inputs": [
        "knip.json",
        "packages/*/src/**",
        "packages/*/package.json"
      ]
    },
    "//#knip:fix": {
      "cache": false
    }
  }
}
